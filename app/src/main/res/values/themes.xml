<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.ExpenseTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimaryContainer">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
    </style>

    <style name="Theme.ExpenseTracker" parent="Theme.Material3.Light.NoActionBar">

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="materialCardViewStyle">@style/NoTintCardStyle</item>
        <!-- Kill purple tints -->
        <item name="colorPrimary">#E58A00</item>
        <item name="colorPrimaryVariant">#E58A00</item>
        <item name="colorSecondary">#E58A00</item>
        <item name="colorSecondaryVariant">#E58A00</item>
        <item name="colorSecondaryContainer">@android:color/transparent</item>
        <item name="colorTertiary">#E58A00</item>
        <item name="colorTertiaryContainer">@color/background</item>

        <!-- Surface overrides -->
        <item name="colorSurface">@color/background</item>
        <item name="colorSurfaceVariant">@color/background</item>
        <item name="colorSurfaceContainer">@color/background</item>
        <item name="colorSurfaceContainerLow">@color/background</item>
        <item name="colorSurfaceContainerHigh">@color/background</item>
        <item name="colorSurfaceContainerLowest">@color/background</item>
        <item name="colorSurfaceContainerHighest">@color/background</item>
        <item name="android:colorBackground">@color/background</item>

        <!-- Ripple / highlight -->
        <item name="colorControlHighlight">#1A7A6F62</item>

    </style>
    <style name="NoTintCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">0dp</item>
        <item name="cardForegroundColor">@android:color/transparent</item>
    </style>
    <style name="Theme.ExpenseTracker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#E58A00</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.ExpenseTracker</item>
    </style>

    <style name="CircularFAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.RoundedFAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/ActiveIndicatorStyle</item>
    </style>

    <style name="ActiveIndicatorStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="light_orange_indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/orange_color</item>
    </style>

    <style name="DarkSummaryDatePickerTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">#16100B</item>
        <item name="colorPrimaryVariant">#16100B</item>
        <item name="colorAccent">#16100B</item>
        <item name="android:colorBackground">#FFFDF9</item>
        <item name="buttonBarPositiveButtonStyle">@style/SummaryDatePickerButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/SummaryDatePickerButtonStyle</item>
    </style>

    <style name="SummaryDatePickerButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#16100B</item>
    </style>

    <style name="BottomSheetDialogNoShadow" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearanceOverlay">@style/BottomSheetCornerStyle</item>
    </style>

    <style name="BottomSheetCornerStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>