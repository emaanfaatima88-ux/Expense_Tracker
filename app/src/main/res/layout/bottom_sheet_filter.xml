<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_filter_sheet"
    android:paddingBottom="24dp">

    <View
        android:id="@+id/sheetHandle"
        android:layout_width="42dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="22dp"
        android:background="@drawable/bg_sheet_handle" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="22dp">

        <TextView
            android:id="@+id/txtFilterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Filter &amp; sort"
            android:textColor="#1A1612"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseFilter"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_close_circle"
            android:padding="7dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#857B6F" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SORT BY"
                android:textColor="#A49B86"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="26dp">

                <TextView
                    android:id="@+id/chipSortNewest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="Newest"
                    android:paddingHorizontal="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/chipSortOldest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="Oldest"
                    android:paddingHorizontal="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/chipSortHighest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="Highest"
                    android:paddingHorizontal="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/chipSortLowest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="Lowest"
                    android:paddingHorizontal="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE RANGE"
                android:textColor="#A49B86"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="26dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipDateAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="All time"
                        android:paddingHorizontal="16dp"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/chipDateMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:text="This month"
                        android:paddingHorizontal="16dp"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/chipDate30Days"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:text="Last 30 days"
                        android:paddingHorizontal="16dp"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/chipDate7Days"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:text="Last 7 days"
                        android:paddingHorizontal="16dp"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORY"
                android:textColor="#A49B86"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/filterCategoryChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="10dp"
                app:singleSelection="true"
                android:layout_marginBottom="30dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnResetFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Reset"
            android:textAllCaps="false"
            android:textColor="#1A1612"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnApplyFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Apply"
            android:textAllCaps="false"
            android:textColor="#FFFDF9"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent" />
    </LinearLayout>

</LinearLayout>