<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_begin="14dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="22dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="22dp" />

        <ImageButton
            android:id="@+id/btnBackNavigation"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_notification_circle"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            app:tint="#1A1612"

            android:scaleType="centerInside"
            android:padding="8dp"

            android:layout_marginStart="-8dp"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toTopOf="@id/guidelineTop" />

        <TextView
            android:id="@+id/txtToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Budget"
            android:textColor="#1A1612"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBackNavigation"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toTopOf="@id/guidelineTop" />

        <TextView
            android:id="@+id/lblMonthlyBudget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="MONTHLY BUDGET"
            android:textColor="#A49B86"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintTop_toBottomOf="@id/btnBackNavigation" />

        <TextView
            android:id="@+id/txtCurrentMonthYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="May 2026"
            android:textColor="#1A1612"
            android:textSize="28sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintTop_toBottomOf="@id/lblMonthlyBudget" />

        <LinearLayout
            android:id="@+id/cardRingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="#FFFDF9"
            android:padding="20dp"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintTop_toBottomOf="@id/txtCurrentMonthYear">

            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressBudgetRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    app:indicatorSize="170dp"
                    app:trackThickness="12dp"
                    app:trackColor="#F5EFE4"
                    app:indicatorColor="#D47216"
                    android:max="100"
                    app:indicatorDirectionCircular="clockwise"
                    android:progress="0"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtProgressPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#1A1612"
                        android:textSize="32sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OF BUDGET"
                        android:textColor="#A49B86"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </FrameLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:paddingHorizontal="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPENT"
                        android:textColor="#A49B86"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView
                        android:id="@+id/txtSpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 71,269"
                        android:textColor="#B05C1D"
                        android:textSize="18sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentEnd="true"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REMAINING"
                        android:textColor="#A49B86"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView
                        android:id="@+id/txtRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 48,731"
                        android:textColor="#D47216"
                        android:textSize="18sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#F5EFE4"
                android:padding="14dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#1A1612"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly limit"
                        android:textColor="#A49B86"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/txtMonthlyBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 120,000"
                        android:textColor="#1A1612"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnUpdateBudgetInline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Update"
                    android:textColor="#1A1612"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPacingStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="#FFFDF9"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintTop_toBottomOf="@id/cardRingContainer">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pacing"
                android:textColor="#1A1612"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">
                    <TextView
                        android:id="@+id/txtPacingExpectedTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="By day 22 of 31, expected"
                        android:textColor="#A49B86"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/txtPacingExpectedAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 85,161"
                        android:textColor="#1A1612"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentEnd="true"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/txtPacingStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Under pace"
                        android:textColor="#A49B86"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/txtPacingDifference"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-Rs. 13,892"
                        android:textColor="#B05C1D"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>