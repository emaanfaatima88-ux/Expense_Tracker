<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <!-- SCROLLABLE CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════ -->
            <!--               HEADER                   -->
            <!-- ═══════════════════════════════════════ -->

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_gradient"
                android:paddingStart="22dp"
                android:paddingTop="16dp"
                android:paddingEnd="22dp"
                android:paddingBottom="24dp">

                <!-- TOP RIGHT DECORATIVE CIRCLE -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="-60dp"
                    android:layout_marginEnd="-40dp"
                    android:background="@drawable/bg_circle_glow_large"/>

                <!-- BOTTOM LEFT DECORATIVE CIRCLE -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="-20dp"
                    android:background="@drawable/bg_circle_glow_small"/>

                <!-- GREETING TEXT -->
                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning 👋"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtGreeting"
                    android:paddingTop="4dp"
                    android:text="Track your expenses smartly"
                    android:textColor="#B3FFFFFF"
                    android:textSize="13sp"/>

            </RelativeLayout>

            <!-- ═══════════════════════════════════════ -->
            <!--            SUMMARY CARD                -->
            <!-- (overlaps header using negative margin)-->
            <!-- ═══════════════════════════════════════ -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="-16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- LABEL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL SPENDING"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>

                    <!-- TOTAL AMOUNT -->
                    <TextView
                        android:id="@+id/txtTotalExpense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:text="Rs. 0"
                        android:textColor="#1C1C1E"
                        android:textSize="38sp"
                        android:textStyle="bold"/>

                    <!-- MONTH LABEL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="2dp"
                        android:text="This Month"
                        android:textColor="#8E8E93"
                        android:textSize="13sp"/>

                    <!-- DIVIDER -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginTop="14dp"
                        android:background="#E5E5EA"/>

                    <!-- STATS ROW -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <!-- TRANSACTIONS -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtTransactionCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1C1C1E"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingTop="2dp"
                                android:text="Transactions"
                                android:textColor="#8E8E93"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <!-- VERTICAL DIVIDER -->
                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_vertical"
                            android:background="#E5E5EA"/>

                        <!-- DAILY AVG -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtDailyAvg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rs. 0"
                                android:textColor="#1C1C1E"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingTop="2dp"
                                android:text="Daily Avg"
                                android:textColor="#8E8E93"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <!-- VERTICAL DIVIDER -->
                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_vertical"
                            android:background="#E5E5EA"/>

                        <!-- CATEGORIES -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtCategoryCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1C1C1E"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingTop="2dp"
                                android:text="Categories"
                                android:textColor="#8E8E93"
                                android:textSize="11sp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════ -->
            <!--         RECENT EXPENSES HEADER         -->
            <!-- ═══════════════════════════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingTop="24dp"
                android:paddingEnd="22dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Expenses"
                    android:textColor="#1C1C1E"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#683BB7"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!--            RECYCLER VIEW               -->
            <!--  FIX: Use fixed height or wrap in a   -->
            <!--  container — RecyclerView inside       -->
            <!--  NestedScrollView needs fixed height   -->
            <!--  OR use nestedScrollingEnabled=false   -->
            <!-- ═══════════════════════════════════════ -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="100dp"
                android:background="#FFFFFF"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>